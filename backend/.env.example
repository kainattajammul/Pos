NODE_ENV=development
PORT=4000
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=change-me-refresh-secret-too
JWT_REFRESH_EXPIRES_IN=30d

SUPABASE_URL=https://alrmshmfmkqetlgypoma.supabase.co
SUPABASE_ANON_KEY=sb_publishable_your-key-here
# Server-side uploads to Supabase Storage (Settings → API → service_role)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_BUCKET=repair-category-images
REPAIR_CATEGORY_STORAGE_BUCKET=repair-category-images

# Image storage: supabase (dev) | local (cPanel production)
STORAGE_DRIVER=supabase
# STORAGE_DRIVER=local
# UPLOAD_DIR=/home/cpaneluser/public_html/uploads
# PUBLIC_UPLOAD_URL=https://yourdomain.com/uploads

# App connection — use Session pooler (port 5432) for this Express API.
# Port 6543 (transaction pooler) is for serverless only and often causes P1001 drops locally.
DATABASE_URL=postgresql://postgres.alrmshmfmkqetlgypoma:[YOUR-PASSWORD]@aws-1-ap-northeast-1.pooler.supabase.com:5432/postgres?pgbouncer=true&connect_timeout=30&sslmode=require

# Direct connection — migrations + Prisma Studio (Supabase → Connect → Direct connection)
DIRECT_URL=postgresql://postgres.alrmshmfmkqetlgypoma:[YOUR-PASSWORD]@db.alrmshmfmkqetlgypoma.supabase.co:5432/postgres?sslmode=require

ENABLE_DEV_AUTH_BYPASS=false
