  CONFLICT
}

enum BranchSettingValueType {
  STRING
  NUMBER
  BOOLEAN
  JSON
  DATE
  TIME
  ENUM
  SECRET_REFERENCE
}

enum SecurityRuleCategory {
  AUTHENTICATION
  AUTHORISATION
  NETWORK
  DEVICE
  SESSION
  FINANCIAL
  CUSTOMER_DATA
  INVENTORY
  REPAIRS
  DOCUMENTS
  EXPORTS
  INTEGRATIONS
}

enum SecurityEnforcementMode {
  MONITOR
  WARN
  ENFORCE
}

enum SecurityEventType {
  ACCESS_DENIED
  INVALID_PERMISSION
  LOGIN_RESTRICTED
  IP_RESTRICTED
  DEVICE_RESTRICTED
  RATE_LIMIT_EXCEEDED
  SENSITIVE_EXPORT_ATTEMPT
  LARGE_REFUND_ATTEMPT
  UNAPPROVED_SETTINGS_CHANGE
  SYNC_CONFLICT
  SUSPICIOUS_ACTIVITY
  OTHER
}

enum SecurityEventStatus {
  OPEN
  ACKNOWLEDGED
  RESOLVED
  DISMISSED
}

enum BranchOwnershipType {
  COMPANY_OWNED
  FRANCHISE_OWNED
  JOINT_OWNERSHIP
  PARTNER_MANAGED
  LICENSED
  INDEPENDENT
}

enum BusinessEntityType {
  SHOP_COMPANY
  FRANCHISEE
  FRANCHISOR
  PARTNER
  INDIVIDUAL
  OTHER
}

enum BusinessEntityStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  ARCHIVED
}

enum BranchOwnershipStatus {
  PENDING
  ACTIVE
  EXPIRED
  TERMINATED
  SUSPENDED
}

model BranchSyncConnection {
  id                   Int      @id @default(autoincrement())
  uuid                 String   @unique @default(uuid()) @db.Uuid
  shopId               Int      @map("shop_id")
  branchId             Int      @map("branch_id")

  connectionCode       String   @map("connection_code")
  name                 String
  provider             String
  syncType             BranchSyncType @map("sync_type")
  direction            SyncDirection @default(BIDIRECTIONAL)
  isEnabled            Boolean  @default(true) @map("is_enabled")

  scheduleType         SyncScheduleType @default(MANUAL) @map("schedule_type")
  scheduleExpression   String?  @map("schedule_expression")
  conflictStrategy     SyncConflictStrategy @default(MANUAL_REVIEW) @map("conflict_strategy")

  lastSyncStartedAt    DateTime? @map("last_sync_started_at")
  lastSyncCompletedAt  DateTime? @map("last_sync_completed_at")
  lastSuccessfulSyncAt DateTime? @map("last_successful_sync_at")
  nextScheduledSyncAt  DateTime? @map("next_scheduled_sync_at")

  currentStatus        SyncConnectionStatus @default(IDLE) @map("current_status")
  lastErrorCode        String?  @map("last_error_code")
  lastErrorMessage     String?  @map("last_error_message")

  providerAccountRef   String?  @map("provider_account_ref")
  credentialReference  String?  @map("credential_reference")

  createdById          Int?     @map("created_by_id")
  updatedById          Int?     @map("updated_by_id")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")
  archivedAt           DateTime? @map("archived_at")

  shop    Shop   @relation(fields: [shopId], references: [id], onDelete: Cascade)
  branch  Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)
  jobs    BranchSyncJob[]

  @@unique([branchId, connectionCode])
  @@index([shopId, branchId])
  @@index([syncType])
  @@index([currentStatus])
  @@map("branch_sync_connections")
}

model BranchSyncJob {
  id               Int      @id @default(autoincrement())
  uuid             String   @unique @default(uuid()) @db.Uuid
  jobNumber        String   @unique @map("job_number")

  shopId           Int      @map("shop_id")
  branchId         Int      @map("branch_id")
  connectionId     Int      @map("connection_id")

  status           SyncJobStatus
  triggerType      SyncTriggerType @map("trigger_type")

  startedAt        DateTime? @map("started_at")
  completedAt      DateTime? @map("completed_at")
  failedAt         DateTime? @map("failed_at")

  totalRecords     Int      @default(0) @map("total_records")
  processedRecords Int      @default(0) @map("processed_records")
  createdRecords   Int      @default(0) @map("created_records")
  updatedRecords   Int      @default(0) @map("updated_records")
  skippedRecords   Int      @default(0) @map("skipped_records")
  failedRecords    Int      @default(0) @map("failed_records")
  conflictRecords  Int      @default(0) @map("conflict_records")

  cursor           String?
  checkpoint       Json?
  summary          Json?

  errorCode        String?  @map("error_code")
  errorMessage     String?  @map("error_message")
  retryCount       Int      @default(0) @map("retry_count")

  triggeredById    Int?     @map("triggered_by_id")
  requestId        String?  @map("request_id")
  idempotencyKey   String?  @map("idempotency_key")

  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  shop       Shop                 @relation(fields: [shopId], references: [id], onDelete: Cascade)
  branch     Branch               @relation(fields: [branchId], references: [id], onDelete: Cascade)
  connection BranchSyncConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  items      BranchSyncJobItem[]

  @@index([shopId, branchId])
  @@index([connectionId, status])
  @@index([startedAt])
  @@map("branch_sync_jobs")
}

model BranchSyncJobItem {
  id             Int      @id @default(autoincrement())
  uuid           String   @unique @default(uuid()) @db.Uuid
  syncJobId      Int      @map("sync_job_id")

  entityType     String   @map("entity_type")
  localEntityId  String?  @map("local_entity_id")
  remoteEntityId String?  @map("remote_entity_id")

  status         SyncItemStatus
  action         String?
  errorCode      String?  @map("error_code")
  errorMessage   String?  @map("error_message")
  conflictData   Json?    @map("conflict_data")

  processedAt    DateTime? @map("processed_at")
  createdAt      DateTime @default(now()) @map("created_at")

  syncJob BranchSyncJob @relation(fields: [syncJobId], references: [id], onDelete: Cascade)

  @@index([syncJobId, status])
  @@index([entityType])
  @@map("branch_sync_job_items")
}

model BranchSetting {
  id              Int      @id @default(autoincrement())
  uuid            String   @unique @default(uuid()) @db.Uuid
  shopId          Int      @map("shop_id")
  branchId        Int      @map("branch_id")

  namespace       String
  key             String
  value           Json
  valueType       BranchSettingValueType @map("value_type")
  isEncrypted     Boolean  @default(false) @map("is_encrypted")
  isSystemManaged Boolean  @default(false) @map("is_system_managed")
  isInherited     Boolean  @default(false) @map("is_inherited")
  version         Int      @default(1)

  createdById     Int?     @map("created_by_id")
  updatedById     Int?     @map("updated_by_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  shop   Shop   @relation(fields: [shopId], references: [id], onDelete: Cascade)
  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([branchId, namespace, key])
  @@index([shopId, branchId])
  @@index([namespace])
  @@map("branch_settings")
}

model BranchSettingHistory {
  id           Int      @id @default(autoincrement())
  shopId       Int      @map("shop_id")
  branchId     Int      @map("branch_id")

  namespace    String
  key          String
  oldValue     Json?    @map("old_value")
  newValue     Json?    @map("new_value")
  version      Int
  changeReason String?  @map("change_reason")
  changedById  Int?     @map("changed_by_id")
  changedAt    DateTime @default(now()) @map("changed_at")

  shop   Shop   @relation(fields: [shopId], references: [id], onDelete: Cascade)
  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@index([shopId, branchId])
  @@index([namespace, key])
  @@index([changedAt])
  @@map("branch_setting_history")
}

model BranchSecurityEvent {
  id              Int      @id @default(autoincrement())
  uuid            String   @unique @default(uuid()) @db.Uuid
  shopId          Int      @map("shop_id")
  branchId        Int?     @map("branch_id")

  ruleKey         String?  @map("rule_key")
  eventType       SecurityEventType @map("event_type")
  severity        String   @default("INFO")
  status          SecurityEventStatus @default(OPEN)

  actorUserId     Int?     @map("actor_user_id")
  entityType      String?  @map("entity_type")
  entityId        String?  @map("entity_id")

  description     String?
  metadata        Json?

  ipAddress       String?  @map("ip_address")
  userAgent       String?  @map("user_agent")

  detectedAt      DateTime @default(now()) @map("detected_at")
  resolvedAt      DateTime? @map("resolved_at")
  resolvedById    Int?     @map("resolved_by_id")
  resolutionNotes String?  @map("resolution_notes")

  shop   Shop    @relation(fields: [shopId], references: [id], onDelete: Cascade)
  branch Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)

  @@index([shopId, branchId])
  @@index([eventType])
  @@index([severity])
  @@index([status])
  @@index([detectedAt])
  @@map("branch_security_events")
}

model BusinessEntity {
  id                 Int      @id @default(autoincrement())
  uuid               String   @unique @default(uuid()) @db.Uuid
  shopId             Int      @map("shop_id")

  legalName          String   @map("legal_name")
  tradingName        String?  @map("trading_name")
  entityType         BusinessEntityType @map("entity_type")

  registrationNumber String?  @map("registration_number")
  taxNumber          String?  @map("tax_number")

  contactName        String?  @map("contact_name")
  contactEmail       String?  @map("contact_email")
  contactPhone       String?  @map("contact_phone")

  address            Json?

  status             BusinessEntityStatus @default(ACTIVE)

  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")
  archivedAt         DateTime? @map("archived_at")

  shop               Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)
  branchOwnerships   BranchOwnership[]

  @@index([shopId])
  @@index([legalName])
  @@map("business_entities")
}

model BranchOwnership {
  id                   Int      @id @default(autoincrement())
  uuid                 String   @unique @default(uuid()) @db.Uuid
  shopId               Int      @map("shop_id")
  branchId             Int      @map("branch_id")
  businessEntityId     Int      @map("business_entity_id")

  ownershipType        BranchOwnershipType @map("ownership_type")
  ownershipPercentage  Decimal? @map("ownership_percentage") @db.Decimal(5, 2)

  isPrimaryOwner       Boolean  @default(false) @map("is_primary_owner")
  isOperatingEntity    Boolean  @default(false) @map("is_operating_entity")

  effectiveFrom        DateTime @map("effective_from")
  effectiveUntil       DateTime? @map("effective_until")

  status               BranchOwnershipStatus @default(ACTIVE)

  agreementReference   String?  @map("agreement_reference")
  agreementStoragePath String?  @map("agreement_storage_path")

  notes                String?

  createdById          Int?     @map("created_by_id")
  updatedById          Int?     @map("updated_by_id")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  shop           Shop           @relation(fields: [shopId], references: [id], onDelete: Cascade)
  branch         Branch         @relation(fields: [branchId], references: [id], onDelete: Cascade)
  businessEntity BusinessEntity @relation(fields: [businessEntityId], references: [id], onDelete: Cascade)

  @@index([shopId, branchId])
  @@index([businessEntityId])
  @@index([status])
  @@index([effectiveFrom, effectiveUntil])
  @@map("branch_ownerships")
}
