generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum MemberStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

model User {
  id           Int      @id @default(autoincrement())

  fullName     String   @map("full_name")
  email        String   @unique
  passwordHash String   @map("password_hash")
  phone        String?

  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  memberships  ShopMember[]

  @@map("users")
}

model Shop {
  id        Int      @id @default(autoincrement())

  name      String
  email     String?
  phone     String?

  vatNumber String?  @map("vat_number")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  branches         Branch[]
  members          ShopMember[]
  roles            Role[]
  repairCategories    RepairCategory[]
  repairManufacturers RepairManufacturer[]
  repairDevices       RepairDevice[]
  repairDeviceSeries  RepairDeviceSeries[]
  repairDeviceIssues  RepairDeviceIssue[]
  repairDeviceParts   RepairDevicePart[]

  @@map("shops")
}

model Branch {
  id        Int      @id @default(autoincrement())

  shopId    Int      @map("shop_id")

  name      String
  address   String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  shop      Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)

  members   BranchMemberRole[]

  @@unique([id, shopId])
  @@index([shopId])

  @@map("branches")
}

model ShopMember {
  id        Int          @id @default(autoincrement())

  userId    Int          @map("user_id")
  shopId    Int          @map("shop_id")

  status    MemberStatus @default(ACTIVE)

  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  shop      Shop         @relation(fields: [shopId], references: [id], onDelete: Cascade)

  shopRoles   ShopMemberRole[]
  branchRoles BranchMemberRole[]

  @@unique([userId, shopId])
  @@unique([id, shopId])
  @@index([shopId])
  @@index([userId])

  @@map("shop_members")
}

model Role {
  id        Int      @id @default(autoincrement())

  shopId    Int      @map("shop_id")

  name      String

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  shop      Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)

  permissions RolePermission[]
  shopMembers ShopMemberRole[]
  branchMembers BranchMemberRole[]

  @@unique([shopId, name])
  @@unique([id, shopId])
  @@index([shopId])

  @@map("roles")
}

model Permission {
  id        Int      @id @default(autoincrement())

  key       String   @unique
  module    String

  createdAt DateTime @default(now()) @map("created_at")

  roles     RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       Int @map("role_id")
  permissionId Int @map("permission_id")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])

  @@map("role_permissions")
}

model ShopMemberRole {
  id           Int @id @default(autoincrement())

  shopId       Int @map("shop_id")
  shopMemberId Int @map("shop_member_id")
  roleId       Int @map("role_id")

  shopMember   ShopMember @relation(fields: [shopMemberId, shopId], references: [id, shopId], onDelete: Cascade)
  role         Role       @relation(fields: [roleId, shopId], references: [id, shopId], onDelete: Cascade)

  assignedAt   DateTime   @default(now()) @map("assigned_at")

  @@unique([shopMemberId, roleId])
  @@index([shopId])
  @@index([roleId])

  @@map("shop_member_roles")
}

model BranchMemberRole {
  id           Int @id @default(autoincrement())

  shopId       Int @map("shop_id")
  branchId     Int @map("branch_id")
  shopMemberId Int @map("shop_member_id")
  roleId       Int @map("role_id")

  shopMember   ShopMember @relation(fields: [shopMemberId, shopId], references: [id, shopId], onDelete: Cascade)
  branch       Branch     @relation(fields: [branchId, shopId], references: [id, shopId], onDelete: Cascade)
  role         Role       @relation(fields: [roleId, shopId], references: [id, shopId], onDelete: Cascade)

  assignedAt   DateTime   @default(now()) @map("assigned_at")

  @@unique([shopMemberId, branchId, roleId])
  @@index([shopId])
  @@index([branchId])
  @@index([roleId])

  @@map("branch_member_roles")
}

model RepairCategory {
  id        Int      @id @default(autoincrement())

  shopId    Int      @map("shop_id")
  name      String
  slug      String
  iconKey   String   @default("wrench") @map("icon_key")
  imageUrl  String?  @map("image_url")
  sortOrder Int      @default(0) @map("sort_order")
  isDefault Boolean  @default(false) @map("is_default")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  shop          Shop                 @relation(fields: [shopId], references: [id], onDelete: Cascade)
  manufacturers RepairManufacturer[]
  devices       RepairDevice[]
  deviceSeries  RepairDeviceSeries[]
  deviceIssues  RepairDeviceIssue[]
  deviceParts   RepairDevicePart[]

  @@unique([shopId, slug])
  @@unique([shopId, name])
  @@index([shopId])

  @@map("repair_categories")
}

model RepairManufacturer {
  id               Int      @id @default(autoincrement())

  shopId           Int      @map("shop_id")
  repairCategoryId Int      @map("repair_category_id")
  name             String
  slug             String
  iconKey          String   @default("smartphone") @map("icon_key")
  imageUrl         String?  @map("image_url")
  logoSlug         String?  @map("logo_slug")
  sortOrder        Int      @default(0) @map("sort_order")
  isDefault        Boolean  @default(false) @map("is_default")

  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  shop             Shop           @relation(fields: [shopId], references: [id], onDelete: Cascade)
  repairCategory   RepairCategory @relation(fields: [repairCategoryId], references: [id], onDelete: Cascade)
  devices          RepairDevice[]
  deviceSeries     RepairDeviceSeries[]
  deviceIssues     RepairDeviceIssue[]
  deviceParts      RepairDevicePart[]

  @@unique([shopId, repairCategoryId, slug])
  @@unique([shopId, repairCategoryId, name])
  @@index([shopId])
  @@index([repairCategoryId])

  @@map("repair_manufacturers")
}

model RepairDeviceSeries {
  id                   Int      @id @default(autoincrement())

  shopId               Int      @map("shop_id")
  repairCategoryId     Int      @map("repair_category_id")
  repairManufacturerId Int      @map("repair_manufacturer_id")
  name                 String
  slug                 String
  sortOrder            Int      @default(0) @map("sort_order")

  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  shop               Shop               @relation(fields: [shopId], references: [id], onDelete: Cascade)
  repairCategory     RepairCategory     @relation(fields: [repairCategoryId], references: [id], onDelete: Cascade)
  repairManufacturer RepairManufacturer @relation(fields: [repairManufacturerId], references: [id], onDelete: Cascade)
  devices            RepairDevice[]

  @@unique([shopId, repairManufacturerId, slug])
  @@unique([shopId, repairManufacturerId, name])
  @@index([shopId])
  @@index([repairCategoryId])
  @@index([repairManufacturerId])

  @@map("repair_device_series")
}

model RepairDevice {
  id                   Int      @id @default(autoincrement())

  shopId               Int      @map("shop_id")
  repairCategoryId     Int      @map("repair_category_id")
  repairManufacturerId Int      @map("repair_manufacturer_id")
  repairDeviceSeriesId Int?     @map("repair_device_series_id")
  name                 String
  slug                 String
  imageUrl             String?  @map("image_url")
  iconVariant          String?  @map("icon_variant")
  sortOrder            Int      @default(0) @map("sort_order")
  isDefault            Boolean  @default(false) @map("is_default")

  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  shop               Shop               @relation(fields: [shopId], references: [id], onDelete: Cascade)
  repairCategory     RepairCategory     @relation(fields: [repairCategoryId], references: [id], onDelete: Cascade)
  repairManufacturer RepairManufacturer @relation(fields: [repairManufacturerId], references: [id], onDelete: Cascade)
  repairDeviceSeries RepairDeviceSeries? @relation(fields: [repairDeviceSeriesId], references: [id], onDelete: SetNull)
  issues             RepairDeviceIssue[]
  parts              RepairDevicePart[]

  @@unique([shopId, repairManufacturerId, slug])
  @@unique([shopId, repairManufacturerId, name])
  @@index([shopId])
  @@index([repairCategoryId])
  @@index([repairManufacturerId])
  @@index([repairDeviceSeriesId])

  @@map("repair_devices")
}

model RepairDeviceIssue {
  id                   Int      @id @default(autoincrement())

  shopId               Int      @map("shop_id")
  repairCategoryId     Int      @map("repair_category_id")
  repairManufacturerId Int      @map("repair_manufacturer_id")
  repairDeviceId       Int      @map("repair_device_id")
  name                 String
  slug                 String
  price                Decimal  @default(0) @db.Decimal(10, 2)
  iconKey              String   @default("diagnostic") @map("icon_key")
  imageUrl             String?  @map("image_url")
  sortOrder            Int      @default(0) @map("sort_order")
  isDefault            Boolean  @default(false) @map("is_default")

  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  shop               Shop               @relation(fields: [shopId], references: [id], onDelete: Cascade)
  repairCategory     RepairCategory     @relation(fields: [repairCategoryId], references: [id], onDelete: Cascade)
  repairManufacturer RepairManufacturer @relation(fields: [repairManufacturerId], references: [id], onDelete: Cascade)
  repairDevice       RepairDevice       @relation(fields: [repairDeviceId], references: [id], onDelete: Cascade)

  @@unique([shopId, repairDeviceId, slug])
  @@unique([shopId, repairDeviceId, name])
  @@index([shopId])
  @@index([repairDeviceId])

  @@map("repair_device_issues")
}

model RepairDevicePart {
  id                   Int      @id @default(autoincrement())

  shopId               Int      @map("shop_id")
  repairCategoryId     Int      @map("repair_category_id")
  repairManufacturerId Int      @map("repair_manufacturer_id")
  repairDeviceId       Int      @map("repair_device_id")
  name                 String
  slug                 String
  price                Decimal  @default(0) @db.Decimal(10, 2)
  onHand               Int      @default(0) @map("on_hand")
  imageVariant         String   @default("screen") @map("image_variant")
  imageUrl             String?  @map("image_url")
  sortOrder            Int      @default(0) @map("sort_order")
  isDefault            Boolean  @default(false) @map("is_default")

  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  shop               Shop               @relation(fields: [shopId], references: [id], onDelete: Cascade)
  repairCategory     RepairCategory     @relation(fields: [repairCategoryId], references: [id], onDelete: Cascade)
  repairManufacturer RepairManufacturer @relation(fields: [repairManufacturerId], references: [id], onDelete: Cascade)
  repairDevice       RepairDevice       @relation(fields: [repairDeviceId], references: [id], onDelete: Cascade)

  @@unique([shopId, repairDeviceId, slug])
  @@unique([shopId, repairDeviceId, name])
  @@index([shopId])
  @@index([repairDeviceId])

  @@map("repair_device_parts")
}